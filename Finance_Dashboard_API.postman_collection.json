{
  "info": {
    "name": "Finance Dashboard API",
    "description": "Complete API collection for the Finance Data Processing and Access Control Backend. Includes authentication, user management, financial record CRUD, and dashboard analytics endpoints.\n\n## Getting Started\n1. Run `npm run seed` to populate the database\n2. Use the **Login** request to get a JWT token\n3. The token is automatically saved to the `token` collection variable\n4. All authenticated requests use `{{token}}` in the Authorization header\n\n## Test Accounts\n| Email | Password | Role |\n|---|---|---|\n| admin@example.com | admin123 | admin |\n| analyst@example.com | analyst123 | analyst |\n| viewer@example.com | viewer123 | viewer |",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "description": "User registration, login, and profile endpoints.",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/register",
              "host": ["{{baseUrl}}"],
              "path": ["users", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"viewer\"\n}"
            },
            "description": "Register a new user account. Role is optional and defaults to 'viewer'. Available roles: admin, analyst, viewer."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('token', res.token);",
                  "    console.log('Token saved to collection variable');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/login",
              "host": ["{{baseUrl}}"],
              "path": ["users", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\"\n}"
            },
            "description": "Login with email and password. Returns a JWT token that is automatically saved to the `token` collection variable for use in subsequent requests."
          },
          "response": []
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/me",
              "host": ["{{baseUrl}}"],
              "path": ["users", "me"]
            },
            "description": "Get the profile of the currently authenticated user. Requires a valid JWT token."
          },
          "response": []
        }
      ]
    },
    {
      "name": "User Management (Admin)",
      "description": "Admin-only endpoints for managing users. Requires `manage:users` permission.",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            },
            "description": "List all registered users. Admin only."
          },
          "response": []
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["users", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "PASTE_USER_ID_HERE",
                  "description": "MongoDB ObjectId of the user"
                }
              ]
            },
            "description": "Get a specific user by their ID. Admin only."
          },
          "response": []
        },
        {
          "name": "Update User (Role/Status)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/users/:id",
              "host": ["{{baseUrl}}"],
              "path": ["users", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "PASTE_USER_ID_HERE",
                  "description": "MongoDB ObjectId of the user"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"analyst\",\n  \"isActive\": true\n}"
            },
            "description": "Update a user's role or active status. Admin only. Available roles: admin, analyst, viewer."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Financial Records",
      "description": "CRUD operations for financial records. Read access requires `read:records`, write/delete requires admin role.",
      "item": [
        {
          "name": "Get All Records",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/records?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["records"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (default: 1)"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Records per page (default: 20)"
                },
                {
                  "key": "type",
                  "value": "income",
                  "description": "Filter by 'income' or 'expense'",
                  "disabled": true
                },
                {
                  "key": "category",
                  "value": "Salary",
                  "description": "Filter by category (partial match)",
                  "disabled": true
                },
                {
                  "key": "startDate",
                  "value": "2025-01-01",
                  "description": "Filter records from this date (ISO format)",
                  "disabled": true
                },
                {
                  "key": "endDate",
                  "value": "2025-12-31",
                  "description": "Filter records until this date (ISO format)",
                  "disabled": true
                },
                {
                  "key": "minAmount",
                  "value": "100",
                  "description": "Minimum amount filter",
                  "disabled": true
                },
                {
                  "key": "maxAmount",
                  "value": "5000",
                  "description": "Maximum amount filter",
                  "disabled": true
                }
              ]
            },
            "description": "List financial records with optional filters and pagination. Disabled query params can be enabled as needed."
          },
          "response": []
        },
        {
          "name": "Get Record by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/records/:id",
              "host": ["{{baseUrl}}"],
              "path": ["records", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "PASTE_RECORD_ID_HERE",
                  "description": "MongoDB ObjectId of the record"
                }
              ]
            },
            "description": "Get a single financial record by its ID."
          },
          "response": []
        },
        {
          "name": "Create Record",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/records",
              "host": ["{{baseUrl}}"],
              "path": ["records"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 2500,\n  \"type\": \"income\",\n  \"category\": \"Salary\",\n  \"description\": \"March 2025 salary payment\",\n  \"date\": \"2025-03-15T00:00:00.000Z\"\n}"
            },
            "description": "Create a new financial record. Admin only. Required fields: amount (positive number), type (income/expense), category. Optional: description (max 500 chars), date (ISO format, defaults to now)."
          },
          "response": []
        },
        {
          "name": "Update Record",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/records/:id",
              "host": ["{{baseUrl}}"],
              "path": ["records", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "PASTE_RECORD_ID_HERE",
                  "description": "MongoDB ObjectId of the record"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 3000,\n  \"description\": \"Updated salary amount\"\n}"
            },
            "description": "Update an existing financial record. Admin only. All fields are optional — only provided fields are updated."
          },
          "response": []
        },
        {
          "name": "Delete Record",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/records/:id",
              "host": ["{{baseUrl}}"],
              "path": ["records", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "PASTE_RECORD_ID_HERE",
                  "description": "MongoDB ObjectId of the record"
                }
              ]
            },
            "description": "Soft delete a financial record (sets isDeleted: true). Admin only. The record is not permanently removed from the database."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Dashboard Analytics",
      "description": "Aggregated analytics endpoints. Requires `read:dashboard` permission (all authenticated roles).",
      "item": [
        {
          "name": "Get Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/dashboard/summary",
              "host": ["{{baseUrl}}"],
              "path": ["dashboard", "summary"]
            },
            "description": "Get total income, total expenses, net balance, and record count."
          },
          "response": []
        },
        {
          "name": "Get Category Breakdown",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/dashboard/categories",
              "host": ["{{baseUrl}}"],
              "path": ["dashboard", "categories"]
            },
            "description": "Get income and expense totals grouped by category."
          },
          "response": []
        },
        {
          "name": "Get Monthly Trends",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/dashboard/trends",
              "host": ["{{baseUrl}}"],
              "path": ["dashboard", "trends"]
            },
            "description": "Get monthly income vs expense trends over time."
          },
          "response": []
        },
        {
          "name": "Get Recent Activity",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/dashboard/recent",
              "host": ["{{baseUrl}}"],
              "path": ["dashboard", "recent"]
            },
            "description": "Get the most recent financial transactions."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Health Check",
      "description": "Server health monitoring.",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Check if the server is running. No authentication required."
          },
          "response": []
        }
      ]
    }
  ]
}
